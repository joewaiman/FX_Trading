# ─── Data Source ─────────────────────────────────────────────────────────────
# oanda | metatrader
DATA_SOURCE=oanda

# ─── Broker ───────────────────────────────────────────────────────────────────
# ib | fxcm | metatrader
BROKER=ib

# ─── Trading Config ───────────────────────────────────────────────────────────
PORTFOLIO_VALUE_USD=10000
MAX_TRADE_SIZE_USD=1000
MAX_TRADES_PER_DAY=5
RISK_PER_TRADE=0.01
PAPER_TRADING=true

# ─── OANDA (data source) ──────────────────────────────────────────────────────
# Practice: https://api-fxpractice.oanda.com
# Live:     https://api-fxtrade.oanda.com
OANDA_API_KEY=
OANDA_ACCOUNT_ID=
OANDA_BASE_URL=https://api-fxpractice.oanda.com

# ─── Interactive Brokers (Client Portal API) ──────────────────────────────────
# Start the IB Gateway or TWS, then enable Client Portal API on port 5000
# Docs: https://interactivebrokers.github.io/cpwebapi/
IB_BASE_URL=https://localhost:5000/v1/api
IB_ACCOUNT_ID=

# ─── FXCM ────────────────────────────────────────────────────────────────────
# Demo: https://api-demo.fxcm.com
# Live: https://api.fxcm.com
FXCM_API_KEY=
FXCM_ACCOUNT_ID=
FXCM_BASE_URL=https://api-demo.fxcm.com

# ─── MetaTrader REST Bridge ───────────────────────────────────────────────────
# Requires a REST bridge EA running in MT4/MT5 (e.g. REST-Bridge, DWX Connect)
MT_REST_URL=http://localhost:8080
MT_API_KEY=
